# NetWatch 配置示例
# 复制到 ~/Library/Application Support/NetWatch/ 并修改

# Surge HTTP 代理端口（默认 6152）
SURGE_HTTP_PORT=6152

# Surge SOCKS5 代理端口（默认 6153）
SURGE_SOCKS_PORT=6153

# 进程名（用于检测是否在运行）
SURGE_PROCESS="Surge"

# 国内基准测试网站
DOMESTIC_URL="https://www.baidu.com"

# 国外探测地址（用轻量 204 探针）
FOREIGN_DIRECT_URL="https://www.gstatic.com/generate_204"
FOREIGN_PROXY_URL="https://www.gstatic.com/generate_204"

# 国外延迟超过此值（毫秒）= 疑似限速
SLOW_MS=3000

# 采样日志保留天数
RETAIN_DAYS=14
